{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://limecloud.github.io/agentapp/schemas/app-manifest.schema.json",
  "title": "Agent App Manifest",
  "type": "object",
  "required": [
    "name",
    "description",
    "version",
    "status",
    "appType"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "ready",
        "needs-review",
        "deprecated",
        "archived"
      ]
    },
    "appType": {
      "type": "string",
      "enum": [
        "agent-app",
        "workflow-app",
        "domain-app",
        "customer-app",
        "custom"
      ]
    },
    "runtimeTargets": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "local",
          "hybrid",
          "server-assisted"
        ]
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "knowledgeTemplates": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "skillRefs": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "toolRefs": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "artifactTypes": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "evals": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "presentation": {
      "type": "object"
    },
    "compatibility": {
      "type": "object"
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
